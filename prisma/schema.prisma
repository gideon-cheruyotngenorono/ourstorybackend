generator client {
  provider   = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String               @id @default(uuid())
  email               String               @unique
  password            String?
  googleId            String?              @unique
  displayName         String
  avatarUrl           String?
  avatarPath          String?
  fcmToken            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  couplesAsPartnerA   Couple[]             @relation("PartnerA")
  couplesAsPartnerB   Couple[]             @relation("PartnerB")
  gratitudeEntries    GratitudeEntry[]
  jarReasonsAdded     JarReason[]
  lettersAuthored     Letter[]
  messagesSent        Message[]
  notesCreated        Note[]
  passwordResetTokens PasswordResetToken[]
  prayersCreated      Prayer[]
  reflections          Reflection[]
  timelineEvents       TimelineEvent[]
  notificationSettings UserNotificationSettings?
  role                 String               @default("user")
  isActive             Boolean              @default(true)
  auditLogs            AdminAuditLog[]      @relation("AdminAction")
  announcements        Announcement[]       @relation("AdminAnnouncements")
  refreshTokens        RefreshToken[]
  devices              Device[]
  notifications        Notification[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Couple {
  id               String           @id @default(uuid())
  partnerAId       String
  partnerBId       String?
  anniversaryDate  DateTime?
  inviteCode       String?          @unique
  createdAt        DateTime         @default(now())
  partnerA         User             @relation("PartnerA", fields: [partnerAId], references: [id])
  partnerB         User?            @relation("PartnerB", fields: [partnerBId], references: [id])
  gratitudeEntries GratitudeEntry[]
  jarReasons       JarReason[]
  letters          Letter[]
  messages         Message[]
  notes            Note[]
  prayers          Prayer[]
  reflections      Reflection[]
  timelineEvents   TimelineEvent[]
  favoriteVerses   CoupleFavoriteVerse[]
}

model Message {
  id           String               @id @default(uuid())
  coupleId     String
  senderId     String
  content      String?
  type         MessageType
  status       MessageStatus        @default(SENT)
  mediaUrl     String?
  thumbnailUrl String?
  fileName     String?
  fileSize     Int?
  duration     Int?
  mimeType     String?
  size         Int?
  isEdited     Boolean              @default(false)
  isDeleted    Boolean              @default(false)
  deliveredAt  DateTime?
  readAt       DateTime?
  deletedAt    DateTime?
  replyToId    String?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  couple       Couple               @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  replyTo      Message?             @relation("MessageReplies", fields: [replyToId], references: [id])
  replies      Message[]            @relation("MessageReplies")
  sender       User                 @relation(fields: [senderId], references: [id])
  reactions    MessageReaction[]
  readReceipts MessageReadReceipt[]
  starredBy    StarredMessage[]
}

model Note {
  id         String   @id @default(uuid())
  coupleId   String
  creatorId  String
  title      String?
  content    String
  isPinned   Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  creator    User     @relation(fields: [creatorId], references: [id])
}

model Letter {
  id        String   @id @default(uuid())
  coupleId  String
  authorId  String
  title     String
  content   String
  deliverAt DateTime
  isDraft   Boolean  @default(true)
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id])
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
}

model Prayer {
  id         String   @id @default(uuid())
  coupleId   String
  creatorId  String
  content    String
  category   String
  isAnswered Boolean  @default(false)
  isArchived Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  creator    User     @relation(fields: [creatorId], references: [id])
}

model Verse {
  id         String   @id @default(uuid())
  reference  String
  text       String
  version    String
  date       DateTime @unique
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Reflection {
  id        String   @id @default(uuid())
  coupleId  String
  userId    String
  content   String
  date      DateTime
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model DiscussionTopic {
  id        String   @id @default(uuid())
  question  String
  type      String
  date      DateTime @unique
  createdAt DateTime @default(now())
}

model TimelineEvent {
  id          String   @id @default(uuid())
  coupleId    String
  title       String
  description String?
  date        DateTime
  type        String
  mediaUrl    String?
  userId      String?
  createdAt   DateTime @default(now())
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user        User?    @relation(fields: [userId], references: [id])
}

model GratitudeEntry {
  id        String   @id @default(uuid())
  coupleId  String
  userId    String
  content   String
  date      DateTime
  isShared  Boolean  @default(false)
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model JarReason {
  id        String   @id @default(uuid())
  coupleId  String
  creatorId String
  content   String
  category  String?
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [creatorId], references: [id])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Device {
  id         String   @id @default(uuid())
  userId     String
  platform   String
  deviceName String?
  fcmToken   String?
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyTopic {
  id        String   @id @default(uuid())
  date      DateTime @unique @default(now())
  content   String
  createdAt DateTime @default(now())
}

model DailyVerse {
  id        String   @id @default(uuid())
  date      DateTime @unique @default(now())
  content   String
  createdAt DateTime @default(now())
}

model MediaFile {
  id        String   @id @default(uuid())
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model MessageReadReceipt {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model StarredMessage {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

model ArchivedChat {
  id         String   @id @default(uuid())
  userId     String
  coupleId   String
  archivedAt DateTime @default(now())
}

model ChatVisibility {
  id            String   @id @default(uuid())
  userId        String
  coupleId      String
  lastClearedAt DateTime @default(now())

  @@unique([userId, coupleId])
}

enum MessageType {
  TEXT
  IMAGE
  VIDEO
  AUDIO
  FILE
  SYSTEM
}

enum MessageStatus {
  SENT
  DELIVERED
  READ
}

model UserNotificationSettings {
  id                String   @id @default(uuid())
  userId            String   @unique
  pushEnabled       Boolean  @default(true)
  dailyReminder     Boolean  @default(true)
  chatNotifications Boolean  @default(true)
  partnerActivity   Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CoupleFavoriteVerse {
  id        String   @id @default(uuid())
  coupleId  String
  verseId   String
  reference String
  text      String
  createdAt DateTime @default(now())
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@unique([coupleId, verseId])
}

model ContentReport {
  id           String   @id @default(uuid())
  reporterId   String
  contentType  String
  contentId    String
  reason       String
  status       String   @default("pending") // pending/resolved/dismissed
  adminNotes   String?
  resolvedById String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Announcement {
  id          String   @id @default(uuid())
  title       String
  message     String
  priority    String   @default("low") // low/medium/high
  createdById String
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  createdBy   User     @relation("AdminAnnouncements", fields: [createdById], references: [id])
}

model AdminAuditLog {
  id         String   @id @default(uuid())
  adminId    String
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime @default(now())
  admin      User     @relation("AdminAction", fields: [adminId], references: [id])
}
